# ─────────────────────────────────────────────────────────────
# Variables d'environnement — Projet Vélib'
# Copier ce fichier en .env et adapter les valeurs si nécessaire
# ─────────────────────────────────────────────────────────────

# ── Chemins des données (relatifs au WORKDIR /app dans le container)
DATA_RAW_DIR=/app/data/raw
DATA_PROCESSED_DIR=/app/data/processed
DATA_OUTPUTS_DIR=/app/data/outputs

# ── Nom du fichier source brut
RAW_FILENAME=dataset_velib_300326.csv

# ── Port du dashboard Streamlit
STREAMLIT_PORT=8501

# ── Hyperparameter tuning
# Nombre d'essais Optuna pour XGBoost
OPTUNA_N_TRIALS=50
# Fraction du train utilisée pour la recherche (accélère le tuning)
TUNING_SAMPLE_FRAC=0.5

# ── MLflow tracking
# Si le service mlflow tourne : http://mlflow:5000
# Sinon : stockage local dans /app/mlruns
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── Reproductibilité
RANDOM_SEED=42

# ── Collecte HuggingFace
# Token HuggingFace avec accès Write (Settings → Access Tokens)
HF_TOKEN=ton_token_hf_write

# Dépôt HuggingFace contenant les CSV de collecte
HF_REPO=voroman/velib-ml-data

# Port du service collecteur (test local)
COLLECTOR_PORT=8080
